#!/bin/bash
clear
c=3 b=4
for j in c b; do
  for i in {0..7}; do
    printf -v $j$i "%b" "\e[${!j}${i}m"
  done
done

user=$(whoami)
host=$(uname -a | awk '{print $2}')
memory=$(free -h)
os=$(source /etc/os-release && echo $PRETTY_NAME)
kernel=$(uname -sr)
wm="$(xprop -id $(xprop -root -notype | awk '$1=="_NET_SUPPORTING_WM_CHECK:"{print $5}') -notype -f _NET_WM_NAME 8t | grep "WM_NAME" | cut -f2 -d \")"
mem=$(free -m | sed -n 's/^Mem:\s\+[0-9]\+\s\+\([0-9]\+\)\s.\+/\1/p')
mem_total=$(free -m | awk '/^Mem:/ {print $2}')
# pkgs="$(xbps-query -l | wc -l)"
shell=$(echo "$SHELL" | awk -F/ '{for ( i=1; i <= NF; i++) sub(".", substr(toupper($i),1,1) , $i); print $NF}')
colors=$(for i in {0..7}; do echo -en "\e[${1}$((30 + $i))mв–Ғв–Ғв–Ғ"; done)

get_uptime() {
  # Uptime works by retrieving the data in total seconds and then
  # converting that data into days, hours and minutes using simple
  # math.
  IFS=. read -r s _ </proc/uptime

  # Convert the uptime from seconds into days, hours and minutes.
  d=$((s / 60 / 60 / 24))
  h=$((s / 60 / 60 % 24))
  m=$((s / 60 % 60))

  # Only append days, hours and minutes if they're non-zero.
  case "$d" in [!0]*) uptime="${uptime}${d}d " ;; esac
  case "$h" in [!0]*) uptime="${uptime}${h}h " ;; esac
  case "$m" in [!0]*) uptime="${uptime}${m}m " ;; esac

  echo ${uptime:-0m}
}

init() {
  init=$(readlink /sbin/init)
  init=${init##*/}
  init=${init%%-*}
  export init
}
init

cat <<EOF
${c0} в–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғ
${c0} в–Һв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Һ ${c2}п„‘ ${c0} ${c3}п„‘ ${c0}${c1} пҷҳ ${c0}в–Һ ${c1}${c4}оӮ°${c1}оӮ° ${c4}$user@${c1}$host
${c0} в–Һ                            в–Һ ${c4}
${c0} в–Һ        ${c4}в–Ҳв–Җв–Җв–Җв–Җв–Җв–Җв–Җв–Җв–Җв–Ҳ${c0}         в–Һ ${c4}OS     ${c7} $os
${c0} в–Һ        ${c4}в–Ҳ         в–Ҳ${c0}         в–Һ ${c4}Kernel ${c7} $kernel
${c0} в–Һ        ${c4}в–Ҳ  в–Ҳ   в–Ҳ  в–Ҳ${c0}         в–Һ ${c4}WM     ${c7} $wm
${c0} в–Һ        ${c0}в–Ҳ         в–Ҳ${c0}         в–Һ ${c4}Shell  ${c7} $shell
${c0} в–Һ        ${c0}в–Җв–Ҳв–„в–„в–„в–„в–„в–„в–„в–Ҳв–Җ${c0}         в–Һ ${c4}Init   ${c7} $init
${c0} в–Һ                            в–Һ ${c4}pkgs   ${c7} $pkgs
${c0} в–Һ                            в–Һ ${c4}uptime ${c7} $(get_uptime)
${c0} в–Һ  п‘Ҡп‘Ҡ ${c4}void  пҖ„  runit ^_^    ${c0} в–Һ ${c4}memory ${c7} $mem / $mem_total$(echo MiB)
${c0} в–Һв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Ғв–Һ $colors
EOF

if [[ $1 == "-b" ]]; then
  for f in {0..6}; do
    echo -en "\033[$((f + 41))m\033[$((f + 30))mв–Ҳв–Ҳв–“в–’в–‘"
  done
  echo -en "\033[37mв–Ҳв–Ҳ\n"
  echo
  for f in {0..6}; do
    echo -en "\033[$((f + 41))m\033[1;$((f + 30))mв–Ҳв–Ҳв–“в–’в–‘"
  done
  echo -en "\033[1;37mв–Ҳв–Ҳ"
  echo -e "\033[0m"
  echo
else
  :
fi
